<body>
    <div class="bio-bg"></div>
    
    <header>
        <div class="container header-content">
            <div class="logo">
                <span class="helix-icon">🧬</span>
                <span class="logo-text">DNA <span class="thin">World</span></span>
            </div>
            <nav>
                <a href="index.html" class="btn-nav">НАЧАЛО</a>
                <a href="facts.html" class="btn-nav">БИБЛИОТЕКА С ФАКТИ</a>
